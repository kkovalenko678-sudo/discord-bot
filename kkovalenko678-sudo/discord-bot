# 🟢 ДЕЙСТВУЮЩИЕ ЛИДЕРЫ
@tree.command(name="check_leaders_act")
async def check_leaders_act(interaction: discord.Interaction, query: str):
    rows = load_rows(CSV_LEADERS_ACT)
    q = normalize(query)

    # ====== 🔥 ALL (ТАБЛИЦА ГОС + ОПГ) ======
    if q == "all":
        gos_list = []
        opg_list = []

        gos_factions = [
            "Правительство",
            "ФСБ",
            "Полиция Южного",
            "Полиция Арзамаса",
            "МЗ Южного",
            "МЗ Арзамаса",
            "Воинская часть",
            "Новостная сеть"
        ]

        for row in rows[3:]:
            if not row[0].strip():
                continue

            name = row[0]
            faction = row[1]
            start = row[2]
            end = row[4]
            leave = row[3] if row[3] else "0"
            discord_tag = row[5] if row[5] else "-"
            transfers = get_transfers_safe(row)

            line = (
                f"👤 **{name}** | {faction}\n"
                f"📅 {start} → {end}\n"
                f"🏖️ Отгулы: {leave} | 💬 {discord_tag}\n"
                f"🔄 Передачи: {transfers}\n"
            )

            if faction in gos_factions:
                gos_list.append(line)
            else:
                opg_list.append(line)

        embed = discord.Embed(
            title="📊 Все действующие лидеры",
            color=0x2ECC71
        )

        if gos_list:
            embed.add_field(
                name="🏛️ ГОС",
                value="\n".join(gos_list[:10]),
                inline=False
            )

        if opg_list:
            embed.add_field(
                name="🔫 ОПГ",
                value="\n".join(opg_list[:10]),
                inline=False
            )

        await interaction.response.send_message(embed=embed)
        return

    # ====== 🔹 ПОИСК ПО НИКУ ======
    for row in rows[3:]:
        if q in normalize(row[0]):
            embed = discord.Embed(title="🟢 Действующий лидер ГОС/ОПГ", color=0x2ECC71)
            embed.add_field(name="👤 Игрок", value=row[0], inline=False)
            embed.add_field(name="🏛️ Фракция", value=row[1], inline=True)
            embed.add_field(name="📅 Назначен", value=row[2], inline=True)
            embed.add_field(name="🏖️ Отгулы", value=row[3], inline=True)
            embed.add_field(name="📆 Конец срока", value=row[4], inline=True)
            embed.add_field(name="💬 Discord", value=row[5], inline=True)
            embed.add_field(name="🔄 Передачи", value=get_transfers_safe(row), inline=True)
            await interaction.response.send_message(embed=embed)
            return

    # ====== 🔹 ПО ФРАКЦИИ ======
    org_map = {
        "мвд": ["Полиция Южного", "Полиция Арзамаса"],
        "мз": ["МЗ Южного", "МЗ Арзамаса"],
        "фсб": ["ФСБ"],
        "правительство": ["Правительство"],
        "вч": ["Воинская часть"],
        "сми": ["Новостная сеть"]
    }

    if q in org_map:
        first = True

        for row in rows[3:]:
            if row[1] in org_map[q]:
                embed = discord.Embed(
                    title=f"🟢 Действующий лидер {row[1]}",
                    color=0x2ECC71
                )

                embed.add_field(name="👤 Игрок", value=row[0], inline=False)
                embed.add_field(name="🏛️ Фракция", value=row[1], inline=True)
                embed.add_field(name="📅 Назначен", value=row[2], inline=True)
                embed.add_field(name="🏖️ Отгулы", value=row[3], inline=True)
                embed.add_field(name="📆 Конец срока", value=row[4], inline=True)
                embed.add_field(name="💬 Discord", value=row[5], inline=True)
                embed.add_field(name="🔄 Передачи", value=get_transfers_safe(row), inline=True)

                if first:
                    await interaction.response.send_message(embed=embed)
                    first = False
                else:
                    await interaction.followup.send(embed=embed)

        return

    await interaction.response.send_message("❌ Ничего не найдено")

