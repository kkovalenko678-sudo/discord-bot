# 📜 ИСТОРИЯ ЛИДЕРОВ (с пагинацией)
@tree.command(name="history_leaders")
async def history_leaders(interaction: discord.Interaction, org: str):
    rows = load_rows(CSV_HISTORY)

    org_map = {
        "правительство": 0,
        "сми": 1,
        "фсб": 2,
        "мвд-а": 3,
        "мвд-ю": 4,
        "вч": 5,
        "мз-а": 6,
        "мз-ю": 7
    }

    org_lower = org.lower()

    if org_lower not in org_map:
        await interaction.response.send_message(
            "❌ Используй: Правительство, СМИ, ФСБ, МВД-А, МВД-Ю, ВЧ, МЗ-А, МЗ-Ю"
        )
        return

    col_index = org_map[org_lower]

    # собираем список
    result = []
    for row in rows[1:]:
        if len(row) > col_index and row[col_index].strip():
            result.append(row[col_index])

    if not result:
        await interaction.response.send_message("❌ Нет данных")
        return

    # 🔥 РАЗБИВКА НА СТРАНИЦЫ (по 20 строк)
    chunk_size = 45
    chunks = [result[i:i + chunk_size] for i in range(0, len(result), chunk_size)]

    first = True

    for page_num, chunk in enumerate(chunks, start=1):
        embed = discord.Embed(
            title=f"📜 История лидеров — {org.upper()} (стр. {page_num}/{len(chunks)})",
            color=0x5865F2
        )

        embed.description = "\n".join(chunk)

        embed.add_field(
            name="ℹ️ Информация",
            value="Список лидеров может быть неточным из-за устаревших данных, ухода участников с канала либо смены ими никнеймов. В списке указан либо ник, либо Discord-тег.",
            inline=False
        )

        if first:
            await interaction.response.send_message(embed=embed)
            first = False
        else:
            await interaction.followup.send(embed=embed)

