# ====== Функции ======
def load_rows(url):
    res = requests.get(url)
    res.encoding = "utf-8"
    return list(csv.reader(StringIO(res.text)))

def load_dict(url):
    res = requests.get(url)
    res.encoding = "utf-8"
    return list(csv.DictReader(StringIO(res.text)))

def normalize(text):
    return text.lower().replace("_", "").replace(" ", "").strip()

def get_transfers_safe(row):
    if len(row) > 7 and row[7].strip():
        return row[7]
    return "0"

def calc_time(start, end):
    try:
        d1 = datetime.strptime(start.strip(), "%d.%m.%Y")
        d2 = datetime.strptime(end.strip(), "%d.%m.%Y")
        delta = d2 - d1
        days = delta.days
        months = days // 30
        years = months // 12
        return f"{years} г. {months % 12} мес. {days % 30} дн."
    except:
        return "неизвестно"

def get_status(end_date):
    try:
        end = datetime.strptime(end_date.strip(), "%d.%m.%Y")
        now = datetime.now()
        return "🟢 Активен" if end >= now else "🔴 Истёк"
    except:
        return "⚠️ Неизвестно"

# =========================
# 🔴 ЧС ГОС
@tree.command(name="check_org")
async def check_org(interaction: discord.Interaction, nickname: str):
    rows = load_rows(CSV_GOS)
    search = normalize(nickname)

    found = []

    # 🔎 поиск
    for row in rows[1:]:
        if search in normalize(row[0]):
            found.append(row)

    if not found:
        await interaction.response.send_message("❌ Игрок не найден")
        return

    # 📤 вывод
    for i, row in enumerate(found, start=1):
        embed = discord.Embed(title=f"🔴 ЧС ГОС #{i}", color=0xED4245)

        status = get_status(row[3])  # статус срока

        embed.add_field(name="👤 Игрок", value=row[0], inline=False)

        embed.add_field(
            name="📅 Дата подачи — Дата выхода",
            value=f"{row[2]} — {row[3]}",
            inline=True
        )

        embed.add_field(
            name="⏳ Срок",
            value=f"{calc_time(row[2], row[3])}\n{status}",
            inline=True
        )

        embed.add_field(name="📌 Причина", value=row[4], inline=False)
        embed.add_field(name="🏛️ Фракция", value=row[5], inline=True)
        embed.add_field(name="⚖️ Степень", value=row[6], inline=True)

        if len(row) > 7 and row[7]:
            embed.add_field(name="📎 Дополнительно", value=row[7], inline=False)

        embed.set_footer(text="Проверка ЧС ГОС")

        if i == 1:
            await interaction.response.send_message(embed=embed)
        else:
            await interaction.followup.send(embed=embed)
            return

    await interaction.response.send_message("❌ Игрок не найден")

