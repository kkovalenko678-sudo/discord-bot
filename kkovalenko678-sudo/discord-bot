# 🔹 КУРАТОРЫ ОПГ
@tree.command(name="check_curator_opg")
async def check_curator_opg(interaction: discord.Interaction, org: str):
    mapping = {
        "курганской": ("Курган", 0xF1C40F, "🟡"),
        "ореховской": ("Орехов", 0x9B59B6, "🟣"),
        "тамбовской": ("Тамбов", 0x2ECC71, "🟢"),
        "кавказской": ("Кавказ", 0x3498DB, "🔵")
    }

    org_lower = org.lower()

    if org_lower not in mapping:
        await interaction.response.send_message(
            "❌ Используйте: Курганской / Ореховской / Тамбовской / Кавказской"
        )
        return

    keyword, color, emoji = mapping[org_lower]
    rows = load_rows(CSV_CURATORS_OPG)
    result = []

    for row in rows:
        for i, cell in enumerate(row):
            if cell and keyword.lower() in cell.lower() and i + 1 < len(row) and row[i + 1]:
                result.append(f"• **{row[i + 1]}** — {cell}")

    if not result:
        await interaction.response.send_message("❌ Кураторы не найдены")
        return

    embed = discord.Embed(title=f"{emoji} Кураторы {org.capitalize()} ОПГ", color=color)
    embed.description = "\n".join(result)
    embed.add_field(name="📊 Всего кураторов", value=f"**{len(result)}**", inline=False)
    embed.set_footer(text="Проверка кураторов ОПГ")

    await interaction.response.send_message(embed=embed)

