# 🔹 КУРАТОРЫ ГОС
@tree.command(name="check_curator_org")
async def check_curator_org(interaction: discord.Interaction, org: str):
    rows = load_rows(CSV_CURATORS)
    result = []

    for row in rows[5:]:
        for i, cell in enumerate(row):
            if org.lower() in cell.lower() and i + 1 < len(row) and row[i + 1]:
                result.append(f"• **{row[i + 1]}** — {cell}")

    if not result:
        await interaction.response.send_message("❌ Кураторы не найдены")
        return

    embed = discord.Embed(title=f"🟠 Кураторы {org.upper()}", color=0xFFA500)
    embed.description = "\n".join(result)
    embed.add_field(name="📊 Всего кураторов", value=f"**{len(result)}**", inline=False)
    embed.set_footer(text="Проверка кураторов ГОС")

    await interaction.response.send_message(embed=embed)

